[sub_resource type="Shader" id="red_eye_shader"]
code = "shader_type canvas_item;

uniform float pulse_speed : hint_range(0.5, 5.0) = 1.5;
uniform float pulse_intensity : hint_range(0.0, 2.0) = 0.8;
uniform float red_threshold : hint_range(0.3, 1.0) = 0.5;

void fragment() {
	vec4 col = texture(TEXTURE, UV);
	float is_red = step(red_threshold, col.r) * step(col.g, 0.3) * step(col.b, 0.3);
	float pulse = (sin(TIME * pulse_speed * 3.14159) * 0.5 + 0.5) * pulse_intensity;
	col.rgb += vec3(pulse * 0.8, pulse * 0.05, pulse * 0.02) * is_red;
	COLOR = col;
}
"

[sub_resource type="ShaderMaterial" id="red_eye_mat"]
shader = SubResource("red_eye_shader")
shader_parameter/pulse_speed = 1.5
shader_parameter/pulse_intensity = 0.8
shader_parameter/red_threshold = 0.5

